# এটা একটা টেমপ্লেট — এটা git-এ থাকে (সবাই দেখে কোন কোন key লাগবে),
# কিন্তু এখানে আসল মান নেই। নিজের মেশিনে/সার্ভারে একটা .env বানিয়ে
# আসল মান বসাও ( .env কখনো git-এ যায় না )।

# ===== Database =====
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=bazar

# ===== JWT =====
JWT_SECRET=a_long_random_secret_string
